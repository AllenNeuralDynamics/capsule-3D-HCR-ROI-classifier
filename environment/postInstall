#!/usr/bin/env bash
set -euxo pipefail

# Install the 3-D HCR ROI-quality classifier. Its pyproject pins the runtime deps
# (numpy, pandas, scipy, scikit-image, zarr, lightgbm, scikit-learn, pyarrow,
# tifffile, tqdm) and the repo vendors the trained model under models/ — which
# run_capsule.py points MFISH_MODELS_DIR at by default.
cd /
git clone https://github.com/AllenNeuralDynamics/mfish-roi-classifier
cd /mfish-roi-classifier && pip install -e .
